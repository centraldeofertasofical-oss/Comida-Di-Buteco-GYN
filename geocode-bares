];

const sleep = ms => new Promise(r => setTimeout(r, ms));
const el = document.getElementById('resultado');

async function geocode(bar) {
  const url = `https://maps.googleapis.com/maps/api/geocode/json?address=${encodeURIComponent(bar.a)}&key=${API_KEY}&language=pt-BR&region=BR`;
  const r = await fetch(url);
  const d = await r.json();
  if (d.status === 'OK') {
    const loc = d.results[0].geometry.location;
    return {n: bar.n, lat: loc.lat, lng: loc.lng};
  }
  return {n: bar.n, lat: null, lng: null, erro: d.status};
}

async function iniciar() {
  el.textContent = 'Iniciando...\n';
  const resultados = [];
  for (let i = 0; i < bares.length; i++) {
    const bar = bares[i];
    el.textContent += `[${i+1}/47] ${bar.n}... `;
    const res = await geocode(bar);
    if (res.lat) {
      el.textContent += `✅ ${res.lat.toFixed(6)}, ${res.lng.toFixed(6)}\n`;
      resultados.push(res);
    } else {
      el.textContent += `❌ ${res.erro}\n`;
    }
    await sleep(200);
  }
  
  // Gera o JSON final
  el.textContent += '\n\n=== COPIE O JSON ABAIXO E MANDE PARA O CLAUDE ===\n\n';
  el.textContent += JSON.stringify(resultados, null, 2);
}
